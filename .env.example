# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Agent ---------------------------------------------------------------
# The coding agent Sunday runs in each sandbox. Default: claude.
# Swap here for another agent (e.g. chatgpt, gemini) — note it must be
# runnable headless inside the Docker sandbox, not just set here.
AGENT=claude

# Model + reasoning effort for the agent above. Swap to match your agent.
MODEL=claude-opus-4-8
MODEL_EFFORT=high            # low | medium | high | xhigh | max

# --- Agent auth ----------------------------------------------------------
# For Claude: a Max subscription token from `claude setup-token`
# ($0 marginal), or an API key. For another agent, replace with its auth var.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Pipeline ------------------------------------------------------------
# Local port the listener receives forwarded GitHub events on. No public
# endpoint — `gh webhook forward --url http://localhost:<port>/` delivers here.
LISTENER_PORT=8787

# Shared secret for `gh webhook forward` deliveries (HMAC-verified; wired later).
WEBHOOK_SECRET=

# Global concurrency cap across ALL repos (one shared agent quota).
MAX_CONCURRENCY=3

# --- Telegram control (optional) -----------------------------------------
# Optional $0 phone channel over polling (getUpdates) — NO public endpoint, no
# tunnel. Unset = disabled: notifications no-op and the command poller never
# starts, pipeline unchanged. Create a bot with @BotFather for the token; message
# the bot, then read your numeric chat id from
# https://api.telegram.org/bot<token>/getUpdates. The chat id is the ONLY authz —
# updates from any other chat are dropped.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
