# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Agent ---------------------------------------------------------------
# The coding agent Sunday runs in each sandbox. Default: claude.
# Swap here for another agent (e.g. chatgpt, gemini) — note it must be
# runnable headless inside the Docker sandbox, not just set here.
AGENT=claude

# Model + reasoning effort for the agent above. Swap to match your agent.
MODEL=claude-opus-4-8
MODEL_EFFORT=high            # low | medium | high | xhigh | max

# --- Agent auth ----------------------------------------------------------
# For Claude: a Max subscription token from `claude setup-token`
# ($0 marginal), or an API key. For another agent, replace with its auth var.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Pipeline ------------------------------------------------------------
# Shared secret for `gh webhook forward` deliveries.
WEBHOOK_SECRET=

# Global concurrency cap across ALL repos (one shared agent quota).
MAX_CONCURRENCY=3
